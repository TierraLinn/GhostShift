{
  "manifest_version": 3,
  "name": "GhostShift",
  "description": "Skips visible ad controls and mutes interruptions where supported.",
  "version": "0.1.0",
  "action": {
    "default_title": "GhostShift",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": ["storage", "tabs"],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://www.facebook.com/*",
        "https://facebook.com/*",
        "http://localhost:8787/install.html",
        "http://localhost:8787/demo-player.html",
        "http://127.0.0.1:8787/install.html",
        "http://127.0.0.1:8787/demo-player.html"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
